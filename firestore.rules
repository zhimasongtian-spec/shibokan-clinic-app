rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 患者ドキュメント本体は空（存在するかどうかだけがログイン確認に使われる）。
    // クライアントから直接読み書きさせない。patientLogin/staffRegisterPatient
    // Cloud Function（Admin SDK・ルールをバイパス）だけがここを操作する。
    // ドキュメントID自体が「電話番号下4桁_生年月日」のキーになっている。
    match /patients/{patientKey} {
      allow read, write: if false;

      // 実際の記録（体重・食事・運動・検査）はここ。
      // 本人（uid=patientKey）か、role=staffのスタッフのみアクセス可。
      match /data/{docId} {
        allow read, write: if request.auth != null &&
          (request.auth.uid == patientKey || request.auth.token.role == "staff");
      }
    }

    // ログイン失敗回数の記録（電話番号下4桁単位）。Cloud Functionのみが操作する。
    match /loginAttempts/{phoneLast4} {
      allow read, write: if false;
    }
  }
}
